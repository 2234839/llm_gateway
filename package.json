    "picomatch": "^4.0.4",
    "uuid": "^14.0.0",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "vite-plugin-pilot": "^1.0.31"
  }
}
